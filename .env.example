# ═══════════════════════════════════════════════════════════════
#  TikTok Clone - Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Admin Panel Credentials (REQUIRED) ─────────────────────
# These MUST be set - the server will not start without them
ADMIN_USER=your_admin_username
ADMIN_PASS=your_strong_password_here

# ── Admin Notification Email (Optional) ────────────────────
# Email to receive OTP alerts (can also be set via /admin/email)
ADMIN_EMAIL=admin@example.com

# ── SMTP Email Configuration (Optional) ────────────────────
# Can be configured via /admin/email UI instead
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM_NAME=TikTok
SMTP_FROM_EMAIL=your-email@gmail.com

# ── Server Configuration ───────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000

# ── Facebook Display Name ──────────────────────────────────
FB_NAME=John Smith
